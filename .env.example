# ============================================
# CUMPLE - Environment Configuration Example
# ============================================
# 
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to git - it contains secrets!
#
# cp .env.example .env
#

# ============================================
# AGENT-ZERO CONFIGURATION
# ============================================

# Google API Key for natural language processing
# Get it from: https://cloud.google.com/docs/authentication/api-keys
API_KEY_GOOGLE=your_google_api_key_here

# Agent-Zero Web UI port and host
WEB_UI_PORT=5000
WEB_UI_HOST=0.0.0.0

# Agent-Zero Web UI Credentials
# Change these to secure values in production
AGENT_ZERO_USER=admin
AGENT_ZERO_PASSWORD=change_me_to_secure_password

# ============================================
# AMAZON AFFILIATE CONFIGURATION
# ============================================

# Amazon Associates affiliate tag
# Get it from: https://affiliate-program.amazon.com/
AMAZON_AFFILIATE_TAG=your_affiliate_tag_here

# ============================================
# CUMPLE APPLICATION CONFIGURATION
# ============================================

# Agent-Zero API endpoint URL
# Local development: http://localhost:5000
# Production: https://agent-zero-api.example.com
VITE_AGENT_ZERO_URL=http://localhost:5000

# Main API endpoint for CUMPLE backend
VITE_API_ENDPOINT=https://api.example.com/v1

# Number of days ahead to search for upcoming events
UPCOMING_EVENTS_DAYS=7

# Frequency of recommendation updates in hours
RECOMMENDATIONS_UPDATE_FREQUENCY=24

# ============================================
# FEATURE FLAGS
# ============================================

# Enable background tasks (event checking, notifications, etc.)
ENABLE_BACKGROUND_TASKS=true

# Enable affiliate links in gift recommendations
ENABLE_AFFILIATE_LINKS=true

# Enable simulated mode for testing (uses mock data)
ENABLE_SIMULATED_MODE=false

# ============================================
# RESOURCE PATHS
# ============================================

# Path to custom prompts directory for Agent-Zero
CUSTOM_PROMPTS_PATH=./cumple-prompts

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Database and Auth provider
# Get it from: https://app.supabase.com
# 
# WARNING: These are public keys, but keep them secure anyway!

# Supabase project URL
VITE_SUPABASE_URL=https://your_project.supabase.co

# Supabase anonymous key (for client-side)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# GOOGLE CUSTOM SEARCH CONFIGURATION
# ============================================
# For searching products and information
# Setup: https://programmablesearchengine.google.com/

# Google API Key for Custom Search
# Get it from: https://cloud.google.com/docs/authentication/api-keys
VITE_GOOGLE_API_KEY=your_google_api_key_here

# Google Custom Search Engine ID
# Create one: https://programmablesearchengine.google.com/cse/create/new
VITE_GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# ============================================
# OPTIONAL: WHATSAPP BUSINESS API
# ============================================
# Uncomment and configure if using WhatsApp notifications
#
# WHATSAPP_BUSINESS_API_URL=https://api.example.com
# WHATSAPP_BUSINESS_ACCOUNT_ID=your_account_id
# WHATSAPP_BUSINESS_ACCESS_TOKEN=your_access_token
# WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ============================================
# OPTIONAL: EMAIL SERVICE CONFIGURATION
# ============================================
# Uncomment and configure if using email notifications
#
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=your_sendgrid_api_key
# SENDER_EMAIL=noreply@cumple.app

# ============================================
# OPTIONAL: OAUTH PROVIDERS
# ============================================
# Uncomment and configure if using social login
#
# GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret
#
# GITHUB_OAUTH_CLIENT_ID=your_github_client_id
# GITHUB_OAUTH_CLIENT_SECRET=your_github_client_secret

# ============================================
# OPTIONAL: ANALYTICS & MONITORING
# ============================================
# Uncomment and configure if using analytics
#
# POSTHOG_API_KEY=your_posthog_api_key
# SENTRY_DSN=your_sentry_dsn

# ============================================
# OPTIONAL: DEVELOPMENT & DEBUGGING
# ============================================
# DEBUG=true
# LOG_LEVEL=debug
